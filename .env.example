# ─── nota / enhance — environment variables ───────────────────────────────
# Copia questo file in `.env.local` per lo sviluppo, e replicalo in
# Project Settings → Environment Variables su Vercel per il deploy.

# ── AI providers ──────────────────────────────────────────────────────────
# OpenRouter (Enhance + Ask AI). Necessaria.
OPENROUTER_API_KEY=
# (opzionale) override di model / referer / sito
OPENROUTER_MODEL=
OPENROUTER_SITE_URL=
OPENROUTER_SITE_NAME=
OPENROUTER_PROVIDER=

# Groq Whisper (trascrizione audio). Necessaria se usi Registra/Importa.
GROQ_API_KEY=
GROQ_TRANSCRIBE_MODEL=

# ── Auth ──────────────────────────────────────────────────────────────────
# Stringa randomica usata per firmare i cookie di sessione (HMAC).
# Generala con: `openssl rand -base64 48`. MIN 16 caratteri.
# In production il server rifiuta di partire se è mancante o troppo corta.
AUTH_SECRET=

# ── Google OAuth (opzionale) ──────────────────────────────────────────────
# Necessari per il pulsante "Continua con Google" sulla pagina di login.
# Se mancano, il pulsante restituisce un errore "OAuth non configurato"
# ma la registrazione email/password continua a funzionare normalmente.
#
# Setup:
#   1. https://console.cloud.google.com → New Project (o esistente)
#   2. APIs & Services → Credentials → "Create Credentials" → "OAuth client ID"
#   3. Application type: "Web application"
#   4. Authorized redirect URIs: aggiungi
#        https://<tuo-dominio>/api/auth/google/callback
#        http://localhost:3000/api/auth/google/callback   (per dev)
#   5. Copia Client ID e Client Secret qui sotto.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Opzionale — se omessa, il server costruisce il redirect dal Host header.
# Utile solo se il deploy gira dietro un proxy che maschera l'origine.
GOOGLE_REDIRECT_URI=

# ── Storage credenziali (solo production / Vercel) ────────────────────────
# In dev queste DUE possono restare vuote: l'app usa `.credentials.json`
# locale (gitignored). Su Vercel collega un Vercel KV / Upstash store al
# progetto e queste vengono popolate in automatico.
KV_REST_API_URL=
KV_REST_API_TOKEN=

# Alternativa Upstash diretta (Vercel Marketplace usa già questi nomi).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ── Storage audio (Vercel Blob) ───────────────────────────────────────────
# Necessario in production per importare file audio > 4.5 MB (limite hard
# del body delle serverless function su Vercel). Provisionare uno store
# "Blob" dal dashboard Vercel popola in automatico questa env. In dev può
# restare vuota: il client carica direttamente via FormData.
BLOB_READ_WRITE_TOKEN=
